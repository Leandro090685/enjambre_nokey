#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Functional test script for <module_name>.
Ejecutar dentro del container Odoo (valores desde workspace.md):
    docker exec <container> python3 \\
        <addons_path>/<repo>/<module>/tests/functional_test.py \\
        -d <db_name>
"""
import argparse
import logging
import os
import sys
import unittest

# Asegurar que Odoo addons-path está disponible (path segun workspace.md / entorno)
ODOO_PATH = os.environ.get('ODOO_PATH', '/opt/odoo')
sys.path.insert(0, ODOO_PATH)

import odoo
from odoo.tests.common import TransactionCase
from odoo.tools import config

_logger = logging.getLogger(__name__)

class FunctionalTest(TransactionCase):
    """Pruebas funcionales del módulo."""

    @classmethod
    def setUpClass(cls):
        super().setUpClass()
        cls.env = cls.env(context=dict(cls.env.context, tracking_disable=True))

    def setUp(self):
        super().setUp()
        # Datos base usados en múltiples tests
        self.company = self.env.company
        self.partner = self.env['res.partner'].create({
            'name': 'Test Partner Functional',
        })

    def test_01_datos_minimos(self):
        """Probar que el flujo no crashea con datos mínimos."""
        ...

    def test_02_precision_calculos(self):
        """Validar que los montos calculados son correctos."""
        ...

    def test_03_edge_cases(self):
        """Probar condiciones límite."""
        ...

def run_tests():
    """Entry point para ejecución standalone."""
    parser = argparse.ArgumentParser()
    parser.add_argument('-d', '--database', required=True, help='Database name')
    args = parser.parse_args()

    config['db_name'] = args.database
    config['http_port'] = '0'  # No levantar servidor HTTP
    config['log_level'] = 'warn'

    odoo.tools.config.parse_config([])
    loader = unittest.TestLoader()
    suite = loader.loadTestsFromTestCase(FunctionalTest)
    runner = unittest.TextTestRunner(verbosity=2)
    result = runner.run(suite)

    sys.exit(0 if result.wasSuccessful() else 1)

if __name__ == '__main__':
    run_tests()
